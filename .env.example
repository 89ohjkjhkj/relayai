# Database (PostgreSQL for production / Neon, Supabase, Vercel Postgres)
# Local dev with SQLite: DATABASE_URL="file:./dev.db" (also change provider in schema.prisma)
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# JWT Secret (generate with: openssl rand -base64 32)
JWT_SECRET="change-me-to-a-random-string"

# Upstream AI Provider Keys (configure in admin panel after first run)
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
DEEPSEEK_API_KEY=""

# App URL (for production)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
